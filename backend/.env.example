APP_NAME=ARCA CONTINENTAL Energy API
API_V1_PREFIX=/api/v1
DEBUG=true
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DB_MODE=sqlserver
DATABASE_MODE=sqlserver
DATABASE_URL=sqlite:///./energy_dashboard.db

SQLSERVER_HOST=POZOSDGO
SQLSERVER_DATABASE=ARCA
SQLSERVER_DRIVER=ODBC Driver 17 for SQL Server
SQLSERVER_USE_WINDOWS_AUTH=true
SQLSERVER_TRUST_CERT=true
SQLSERVER_ENCRYPT=yes

DB_SERVER=POZOSDGO
DB_NAME=ARCA
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_ENCRYPT=yes
DB_TRUST_SERVER_CERTIFICATE=true
DB_TRUSTED_CONNECTION=true

SQLSERVER_USERNAME=
SQLSERVER_PASSWORD=

SQLSERVER_SOURCE_MODE=table
SQLSERVER_SOURCE_TABLE=dbo.v_dashboard_measurements

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com